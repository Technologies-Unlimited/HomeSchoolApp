{
  "name": "home-school-group",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot run server.ts",
    "db:setup": "bun run src/db/setup.ts",
    "db:seed": "bun run src/db/seed.ts",
    "notifications:process": "bun run src/scripts/process-notifications.ts",
    "build": "bun build src/main.ts --outdir=dist --target=browser --minify && bun run scripts/copy-index.ts",
    "preview": "bun run server.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "form-data": "^4.0.5",
    "mailgun.js": "^12.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/bcryptjs": "^2.4.6"
  }
}
